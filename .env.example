# Base RPC
RPC_URL_BASE=https://mainnet.base.org

# Dedicated bot wallet private key (NEVER your main wallet)
BOT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Safety cap (USD)
MAX_USD_CAP=12

# Trading parameters
SLIPPAGE_BPS=60
SAMPLE_SECONDS=5
WINDOW_MINUTES=30
K_SIGMA=1.5
COOLDOWN_SECONDS=300

# Risk controls
MAX_TRADES=3
STOP_AFTER_LOSSES=2

# Swap sizing (portion of balance to use)
USDC_BUY_FRACTION=0.98
WETH_SELL_FRACTION=0.98
